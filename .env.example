# Обязательно
BOT_TOKEN=твой_токен_от_BotFather

# Бесплатный ключ для понимания свободных текстовых вопросов ("куда сегодня?").
# Получить: https://aistudio.google.com/apikey — бесплатно, без карты.
# Без него бот всё равно работает, но понимает только простые ключевые слова
# (сегодня/завтра), а не произвольные формулировки.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Бесплатный тариф Gemini общий на весь ключ (обычно ~1000-1500 запросов в сутки),
# а не на пользователя — эти два лимита защищают от того, что активные пользователи
# "съедят" всю дневную квоту. При достижении бот просто переходит на офлайн-разбор
# по ключевым словам вместо Gemini, ничего не ломается.
GEMINI_DAILY_GLOBAL_LIMIT=700
GEMINI_DAILY_PER_USER_LIMIT=8

# Источник данных о ветре: openmeteo (по умолчанию, бесплатно) | windy (нужен WINDY_API_KEY)
WIND_PROVIDER=openmeteo
WINDY_API_KEY=

# Модель прогноза для openmeteo. best_match — Open-Meteo сам выбирает лучшую модель под координаты (по умолчанию).
# Все модели ниже доступны бесплатно на том же api.open-meteo.com/v1/forecast, просто через параметр &models=.
#
# Нидерланды/Бельгия — та же модель HARMONIE-AROME, что использует SoarCast.nl:
#   knmi_harmonie_arome_netherlands  — NL + Бельгия, 2 км, горизонт 2.5 дня (дальше Open-Meteo докидывает ECMWF)
#   knmi_harmonie_arome_europe       — Центральная/Северная Европа, 5.5 км
#   knmi_seamless                    — HARMONIE + ECMWF на весь срок прогноза
#
# Франция — модель AROME от Météo-France:
#   meteofrance_arome_france         — Франция, 2.5 км
#   meteofrance_arome_france_hd      — Франция, 1.5 км (выше детализация, меньше параметров)
#   meteofrance_seamless             — AROME + ARPEGE на весь срок прогноза
#
# Другие регионы: icon_seamless (DWD, Германия/Европа), gfs_seamless (глобально), ecmwf_ifs025 (глобально)
WEATHER_MODEL=best_match

# Необязательные настройки (можно не трогать — сработают дефолты)
SEARCH_RADIUS_KM=150
MAX_SPOTS_TO_CHECK=8
CACHE_TTL_MINUTES=15
RATE_LIMIT_SECONDS=5
DEFAULT_WEIGHT_KG=75
LOG_LEVEL=info
# Как часто (в минутах) писать в лог сводку метрик: кол-во запросов, ошибок, error rate.
# Текущий снапшот в любой момент доступен на GET /metrics (см. README).
METRICS_LOG_INTERVAL_MINUTES=30
